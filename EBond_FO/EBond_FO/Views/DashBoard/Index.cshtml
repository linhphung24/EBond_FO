@model IEnumerable<EBond_FO.Models.IFG_Corporate_Bond_Info>

@{
    ViewData["Title"] = "Thị trường trái phiếu";
}

<div class="c_ikmhbz c_pni6vl">
    <div class="c_h3i80m">
        <div>
            <h2 class="c_78my79">Thị trường trái phiếu</h2>
            <p class="c_wxx1dh">Dữ liệu từ IFG_Corporate_Bond_Info</p>
        </div>
    </div>

    <div class="c_cgfqtw">
        <!-- ===== DESKTOP BOND TABLE ===== -->
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr class="filter-row">
                        <th colspan="12">
                            <div class="filter-bar">
                                <div>
                                    <span class="label">TCPH:</span>
                                    <select id="filter-tcph">
                                        <option value="">Tất cả</option>
                                        @foreach (var tcph in Model.Select(x => x.TCPH).Where(x => !string.IsNullOrEmpty(x)).Distinct().OrderBy(x => x))
                                        {
                                            <option value="@tcph">@tcph</option>
                                        }
                                    </select>
                                </div>
                                <div class="filter-item">
                                    <span class="label">Trạng thái:</span>
                                    <select id="filter-status">
                                        <option value="">Tất cả</option>
                                        @foreach (var s in Model.Select(x => x.SecurityTradingStatus).Where(x => !string.IsNullOrEmpty(x)).Distinct().OrderBy(x => x))
                                        {
                                            <option value="@s">@s</option>
                                        }
                                    </select>
                                </div>
                                <button class="filter-btn" onclick="applyFilter()">LỌC</button>
                            </div>
                        </th>
                    </tr>
                    <tr>
                        <th>Mã TP</th>
                        <th>Tên</th>
                        <th>TCPH</th>
                        <th>Lãi suất (%)</th>
                        <th>Ngày phát hành</th>
                        <th>Ngày đáo hạn</th>
                        <th>Kỳ hạn</th>
                        <th>Còn lại</th>
                        <th>Mệnh giá</th>
                        <th>Giá khớp</th>
                        <th>KL khớp</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody id="bond-tbody">
                    @foreach (var bond in Model)
                    {
                        <tr data-tcph="@bond.TCPH" data-status="@bond.SecurityTradingStatus">
                            <td>@bond.Symbol</td>
                            <td>@bond.Name</td>
                            <td>@bond.TCPH</td>
                            <td>@bond.INTEREST_RATE</td>
                            <td>@bond.IssueDate</td>
                            <td>@bond.MaturityDate</td>
                            <td>@bond.BOND_PERIOD @bond.PERIOD_UNIT</td>
                            <td>@bond.PERIOD_REMAIN</td>
                            <td>@bond.Parvalue</td>
                            <td>@bond.MatchPrice</td>
                            <td>@bond.MatchQtty</td>
                            <td>@bond.SecurityTradingStatus</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="legend-row">
                        <td colspan="12">
                            <div class="legend-bar">
                                <span>Tổng: <strong>@Model.Count()</strong> trái phiếu</span>
                            </div>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function applyFilter() {
        const tcph   = document.getElementById('filter-tcph').value.toLowerCase();
        const status = document.getElementById('filter-status').value.toLowerCase();
        const rows   = document.querySelectorAll('#bond-tbody tr');

        rows.forEach(row => {
            const rowTcph   = (row.dataset.tcph   || '').toLowerCase();
            const rowStatus = (row.dataset.status || '').toLowerCase();

            const matchTcph   = !tcph   || rowTcph   === tcph;
            const matchStatus = !status || rowStatus === status;

            row.style.display = (matchTcph && matchStatus) ? '' : 'none';
        });
    }
</script>
}
