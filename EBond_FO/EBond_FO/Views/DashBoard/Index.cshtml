@section Scripts {
    <script>
        // XỬ LÍ PHẦN class = "panel"
        const tabs = document.querySelectorAll(".tab");
        const panes = document.querySelectorAll(".tab-pane");

        function activateTab(tabId) {
            tabs.forEach(t => t.classList.toggle("active", t.dataset.tab === tabId));
            panes.forEach(p => p.classList.toggle("active", p.id === tabId));
        }

        tabs.forEach(t => {
            t.addEventListener("click", () => activateTab(t.dataset.tab));
        });
    </script>

    <script>
        // XỬ LÍ NÚT MUA VÀ MODAL
        const modalOverlay = document.querySelector('.modal-overlay');
        const modalOverlay1 = document.querySelector('.modal-overlay1');
        const buyBtns = document.querySelectorAll('.buy-btn');

        buyBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                modalOverlay.style.display = 'flex';
            });
        });

        document.addEventListener("DOMContentLoaded", function () {
            const steps = Array.from(document.querySelectorAll(".step"));
            const panes = Array.from(document.querySelectorAll(".step-pane"));
            const btnNext = document.querySelector(".next");
            const btnBack = document.querySelector(".back");

            function getActiveIndex() {
                return steps.findIndex(s => s.classList.contains("active"));
            }

            function showStep(index) {
                steps.forEach((step, i) => {
                    step.classList.remove("active");
                    if (i < index) step.classList.add("done");
                    else step.classList.remove("done");
                });
                steps[index].classList.add("active");

                panes.forEach(p => {
                    p.style.display = "none";
                    p.classList.remove("active");
                });
                const tabId = steps[index].dataset.tab;
                const activePane = document.getElementById(tabId);
                activePane.classList.add("active");
                activePane.style.display = "";

                if (tabId === "info") btnBack.style.display = "none";
                else btnBack.style.display = "inline-block";

                updateFooterByStep(tabId);
            }

            function resetToFirstStep() { showStep(0); }

            window.closeModal = function () {
                modalOverlay.style.display = 'none';
                modalOverlay1.style.display = 'none';
                resetToFirstStep();
            };

            showStep(getActiveIndex());

            btnNext.addEventListener("click", function () {
                if (getComputedStyle(modalOverlay).display === "none") return;
                const currentIndex = getActiveIndex();
                const currentTab = steps[currentIndex].dataset.tab;
                if (currentTab === "buy") return;
                if (currentIndex < steps.length - 1) showStep(currentIndex + 1);
            });

            btnBack.addEventListener("click", function () {
                if (getComputedStyle(modalOverlay).display === "none") return;
                const currentIndex = getActiveIndex();
                if (currentIndex > 0) showStep(currentIndex - 1);
            });
        });
    </script>

    <script>
        // XỬ LÝ STEP CHO MODAL BÁN
        document.addEventListener("DOMContentLoaded", function () {
            const steps1 = Array.from(document.querySelectorAll(".step1"));
            const panes1 = Array.from(document.querySelectorAll(".step-pane1"));
            const btnNext1 = document.querySelector(".next1");
            const btnBack1 = document.querySelector(".back1");

            if (!steps1.length || !panes1.length) return;

            function getActiveIndex1() {
                const idx = steps1.findIndex(s => s.classList.contains("active"));
                return idx >= 0 ? idx : 0;
            }

            function showStep1(index) {
                steps1.forEach((step, i) => {
                    step.classList.remove("active");
                    if (i < index) step.classList.add("done");
                    else step.classList.remove("done");
                });
                steps1[index].classList.add("active");

                panes1.forEach(p => {
                    p.style.display = "none";
                    p.classList.remove("active");
                });
                const tabId = steps1[index].dataset.tab;
                const activePane1 = document.getElementById(tabId);
                if (activePane1) {
                    activePane1.classList.add("active");
                    activePane1.style.display = "";
                }

                if (btnBack1) {
                    if (tabId === "info1") btnBack1.style.display = "none";
                    else btnBack1.style.display = "inline-block";
                }

                updateFooterByStep1(tabId);
            }

            steps1.forEach((s, i) => s.addEventListener("click", () => showStep1(i)));

            if (btnNext1) {
                btnNext1.addEventListener("click", function () {
                    if (getComputedStyle(modalOverlay1).display === "none") return;
                    const currentIndex1 = getActiveIndex1();
                    if (currentIndex1 < steps1.length - 1) showStep1(currentIndex1 + 1);
                });
            }

            if (btnBack1) {
                btnBack1.addEventListener("click", function () {
                    if (getComputedStyle(modalOverlay1).display === "none") return;
                    const currentIndex1 = getActiveIndex1();
                    if (currentIndex1 > 0) showStep1(currentIndex1 - 1);
                });
            }

            showStep1(getActiveIndex1());
        });

        function updateFooterByStep(stepId) {
            const rateInvest = document.getElementById("rate-invest");
            const principal = document.getElementById("principal");
            if (stepId === "info") { rateInvest.style.display = "none"; principal.style.display = "none"; }
            else if (stepId === "risk") { rateInvest.style.display = "flex"; principal.style.display = "none"; }
            else if (stepId === "buy") { rateInvest.style.display = "flex"; principal.style.display = "flex"; }
        }

        function updateFooterByStep1(stepId) {
            const rateInvest = document.getElementById("rate-invest1");
            const principal = document.getElementById("principal1");
            if (stepId === "info1") { rateInvest.style.display = "none"; principal.style.display = "none"; }
            else if (stepId === "buy1") { rateInvest.style.display = "flex"; principal.style.display = "flex"; }
        }
    </script>

    <script>
        // bật tắt phần left trong id = buy
        const toggleBtn = document.getElementById("toggleBtn");
        const rateDetail = document.getElementById("rateDetail");
        if (toggleBtn && rateDetail) {
            toggleBtn.addEventListener("click", () => {
                rateDetail.classList.toggle("show");
                toggleBtn.classList.toggle("active");
            });
        }
    </script>

    <script>
        // XỬ LÍ PHẦN NHẬP SỐ TIỀN
        function toggleInput() {
            const type = document.querySelector('input[name="type"]:checked').value;
            document.getElementById('tpBox').classList.toggle('hidden', type !== 'tp');
            document.getElementById('moneyBox').classList.toggle('hidden', type !== 'money');
        }
        window.onload = toggleInput;

        function onlyNumber(input) {
            input.value = input.value.replace(/[^0-9]/g, '');
        }
    </script>

    <script>
        // XỬ LÍ PHẦN NGƯỜI GIỚI THIỆU
        const refCheckbox = document.getElementById("refCheckbox");
        const refInput = document.getElementById("refInput");
        if (refCheckbox && refInput) {
            refCheckbox.addEventListener("change", function () {
                refInput.style.display = this.checked ? "block" : "none";
            });
        }
    </script>

    <script>
        // XỬ LÍ PHẦN GIỮ VÀ BÁN Ở ĐẶT LỆNH
        const switchItems = document.querySelectorAll(".switch-item");
        const switchContents = document.querySelectorAll(".content1");

        switchItems.forEach(item => {
            item.addEventListener("click", () => {
                switchItems.forEach(i => i.classList.remove("active"));
                switchContents.forEach(c => c.classList.remove("active"));
                item.classList.add("active");
                document.getElementById(item.dataset.target).classList.add("active");
            });
        });
    </script>

    <script>
        // FILTER MOBILE MBOND
        document.addEventListener("DOMContentLoaded", function () {
            const filterToggle = document.querySelector(".mbond-filter-toggle");
            const overlay = document.querySelector(".mbond-filter-overlay");
            const applyBtn = document.querySelector(".mbond-filter-apply");
            const closeBtns = document.querySelectorAll(".mbond-filter-close");
            const cards = Array.from(document.querySelectorAll(".mbond-card"));

            if (!filterToggle || !overlay || !applyBtn || !cards.length) return;

            filterToggle.addEventListener("click", () => overlay.classList.add("open"));
            closeBtns.forEach(btn => btn.addEventListener("click", () => overlay.classList.remove("open")));
        });
    </script>

    <script>
        // Mua / Bán switch
        function showSell() {
            document.querySelector('.modal-overlay').style.display = 'none';
            document.querySelector('.modal-overlay1').style.display = 'flex';
        }
        function showBuy() {
            document.querySelector('.modal-overlay1').style.display = 'none';
            document.querySelector('.modal-overlay').style.display = 'flex';
        }

        function toggleContent(header) {
            header.parentElement.classList.toggle('active');
        }
    </script>
}
